<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.effect.*?>
<?import javafx.scene.*?>
<?import java.lang.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.effect.DropShadow?>

<AnchorPane prefHeight="640.0" prefWidth="360.0" style="-fx-background-color: linear-gradient(to bottom, #13b0da, #0d8bbf);" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.controllers.ConnexionController">
   <children>
      <!-- Titre -->
      <Text fill="WHITE" layoutX="156.0" layoutY="50.0" strokeType="OUTSIDE" strokeWidth="0.0" text="CONNEXION" textAlignment="CENTER">
         <font>
            <Font name="Arial Bold" size="22.0" />
         </font>
      </Text>

      <!-- Conteneur principal -->
      <VBox alignment="CENTER" layoutX="40.0" layoutY="100.0" prefHeight="278.0" prefWidth="362.0" spacing="20">
         <children>

            <!-- Logo -->
            <ImageView fitHeight="100.0" fitWidth="100.0" preserveRatio="true">
               <image>
                  <Image url="@../img/71xzcr0FFvL.jpg" />
               </image>
            </ImageView>

            <Label fx:id="lblError" textFill="red" visible="false" />


            <!-- Champs de saisie -->
            <TextField fx:id="txtLogin" promptText="Login" style="-fx-background-color: rgba(255, 255, 255, 0.1); -fx-text-fill: white; -fx-border-color: #9643A9; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 10;">
               <VBox.margin>
                  <Insets top="10.0" />
               </VBox.margin>
            </TextField>

            <PasswordField fx:id="txtPassword" promptText="Mot de passe" style="-fx-background-color: rgba(255, 255, 255, 0.1); -fx-text-fill: white; -fx-border-color: #9643A9; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 10;">
            </PasswordField>

            <!-- Boutons -->
            <HBox alignment="CENTER" spacing="20">
               <children>
                  <Button onAction="#handleConnexion" prefHeight="40" prefWidth="140" style="-fx-background-color: linear-gradient(to right, #13b0da, #0d8bbf); -fx-background-radius: 10; -fx-border-radius: 10; -fx-font-size: 16px;" text="Se Connecter" textFill="WHITE">
                     <effect>
                        <DropShadow color="#9643A9" radius="10" />
                     </effect>
                     <cursor>
                        <Cursor fx:constant="HAND" />
                     </cursor>
                  </Button>
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
