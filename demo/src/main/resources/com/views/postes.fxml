<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.fxml.FXML?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.paint.Color?>

<AnchorPane xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.controllers.PosteController" style="-fx-background-color: linear-gradient(to bottom, #13b0da, #0d8bbf);">

    <!-- Titre de la Vue -->
    <Text layoutX="30" layoutY="30" style="-fx-font-size: 24px; -fx-fill: white;" text="Gestion des Postes"/>

    <!-- Bouton Ajouter un Poste -->
    <HBox spacing="10" alignment="CENTER" layoutY="60" AnchorPane.leftAnchor="10" AnchorPane.rightAnchor="10">
        <Button text="Ajouter un Poste" fx:id="btnAjouterPoste" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-size: 14px; -fx-border-radius: 5; -fx-background-radius: 5;" onAction="#openAddPosteWindow" />
    </HBox>

    <!-- GridPane pour afficher les cartes des postes -->
    <GridPane fx:id="gridPostes" layoutX="30" layoutY="120" hgap="10" vgap="10">
        <!-- Les cartes seront ajoutées dynamiquement ici -->
    </GridPane>

    <!-- Boutons de Pagination (centrés en bas) -->
    <HBox spacing="10" alignment="CENTER" AnchorPane.bottomAnchor="20" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">
        <Button text="Précédent" fx:id="btnPrecedent" style="-fx-background-color: rgb(7, 123, 173); -fx-text-fill: white; -fx-font-size: 14px; -fx-border-radius: 5; -fx-background-radius: 5;" onAction="#previousPage" />
        <Button text="Suivant" fx:id="btnSuivant" style="-fx-background-color: rgb(7, 123, 173); -fx-text-fill: white; -fx-font-size: 14px; -fx-border-radius: 5; -fx-background-radius: 5;" onAction="#nextPage" />
    </HBox>

</AnchorPane>