<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<AnchorPane style="-fx-background-color: linear-gradient(to bottom, #13b0da, #0d8bbf);" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.controllers.EditClientController">
   <children>
       <!-- Titre Modifier Client -->
       <Text layoutX="30" layoutY="30" style="-fx-font-size: 24px; -fx-fill: white;" text="Modifier Client" />

       <GridPane hgap="20" layoutX="30" layoutY="80" style="-fx-background-color: transparent;" vgap="20">
      <children>
              <!-- Colonne 1 -->
              <TextField fx:id="nameField" prefWidth="250" promptText="Nom" GridPane.columnIndex="0" GridPane.rowIndex="0" />
              <TextField fx:id="emailField" prefWidth="250" promptText="Email" GridPane.columnIndex="0" GridPane.rowIndex="1" />
              <TextField fx:id="phoneField" prefWidth="250" promptText="Numéro de téléphone" GridPane.columnIndex="0" GridPane.rowIndex="2" />
              <DatePicker fx:id="birthDateField" prefWidth="250" promptText="Date de naissance" GridPane.columnIndex="0" GridPane.rowIndex="3" />
              
              <!-- Colonne 2 -->
              <TextField fx:id="addressField" prefWidth="250" promptText="Adresse" GridPane.columnIndex="1" GridPane.rowIndex="0" />
              <TextField fx:id="loyaltyPointsField" prefWidth="250" promptText="Points de fidélité" GridPane.columnIndex="1" GridPane.rowIndex="1" />
              <ComboBox fx:id="roleComboBox" prefWidth="250" GridPane.columnIndex="1" GridPane.rowIndex="2" />
              
              <!-- Boutons -->
              <Button fx:id="editButton" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-size: 14px; -fx-border-radius: 5; -fx-background-radius: 5;" text="Modifier" GridPane.columnIndex="0" GridPane.columnSpan="2" GridPane.rowIndex="4"  onAction="#editClient"/>
              <Button fx:id="cancelButton" onAction="#cancel" style="-fx-background-color: #F44336; -fx-text-fill: white; -fx-font-size: 14px; -fx-border-radius: 5; -fx-background-radius: 5;" text="Annuler" GridPane.columnIndex="1" GridPane.columnSpan="2" GridPane.rowIndex="4" />
      </children>
         <columnConstraints>
            <ColumnConstraints />
            <ColumnConstraints />
         </columnConstraints>
         <rowConstraints>
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
         </rowConstraints>
       </GridPane>
   </children>
</AnchorPane>
