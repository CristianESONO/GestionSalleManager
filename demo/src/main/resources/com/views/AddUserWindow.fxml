<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Text?>
<?import javafx.geometry.Insets?>

<AnchorPane xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.controllers.AddUserController" style="-fx-background-color: linear-gradient(to bottom, #13b0da, #0d8bbf);">
    <!-- Titre Ajouter Utilisateur -->
    <Text text="Ajouter Utilisateur" style="-fx-font-size: 24px; -fx-fill: white;" layoutX="30" layoutY="30" />

    <!-- Champs pour les informations de base -->
    <TextField fx:id="nameField" promptText="Nom" layoutX="30" layoutY="80" prefWidth="300"/>
    <TextField fx:id="emailField" promptText="Email" layoutX="30" layoutY="130" prefWidth="300"/>
    <PasswordField fx:id="passwordField" promptText="Mot de passe" layoutX="30" layoutY="180" prefWidth="300"/>
    
    <!-- ComboBox pour le rôle -->
    <ComboBox fx:id="roleComboBox" layoutX="30" layoutY="230" prefWidth="300"/>
    
    <!-- Bouton Ajouter -->
    <Button text="Ajouter" fx:id="addButton" layoutX="30" layoutY="280" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-size: 14px; -fx-border-radius: 5; -fx-background-radius: 5;" onAction="#addUser"/>
    
    <!-- Bouton Annuler -->
    <Button text="Annuler" fx:id="cancelButton" layoutX="150" layoutY="280" style="-fx-background-color: #F44336; -fx-text-fill: white; -fx-font-size: 14px; -fx-border-radius: 5; -fx-background-radius: 5;" onAction="#cancel"/>
</AnchorPane>
