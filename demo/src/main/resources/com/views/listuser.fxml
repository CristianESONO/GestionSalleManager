<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.control.Pagination?>

<AnchorPane xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.controllers.UserController" style="-fx-background-color: linear-gradient(to bottom, #13b0da, #0d8bbf);">
    <!-- Titre de la section Clients -->

    <TabPane AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">
        <!-- Onglet Clients -->
        <Tab text="Clients">
            <VBox spacing="10" style="-fx-padding: 10;">
                <!-- Barre de recherche pour Clients -->
                <HBox spacing="10" alignment="CENTER">
                    <TextField fx:id="searchClientField" promptText="Rechercher un client" style="-fx-background-color: white; -fx-border-radius: 5; -fx-font-size: 14px;" prefWidth="200"/>
                    <Button text="Rechercher" fx:id="searchClientButton" style="-fx-background-color: rgb(7, 123, 173);  -fx-text-fill: white; -fx-font-size: 14px; -fx-border-radius: 5; -fx-background-radius: 5;"/>
                </HBox>

                <!-- TableView pour Clients -->
                <TableView fx:id="clientTable" style="-fx-background-color: rgba(255, 255, 255, 0.1); -fx-background-radius: 10;">
                    <columns>
                        <TableColumn text="Nom" fx:id="nameClientColumn" prefWidth="250" />
                        <TableColumn text="Téléphone" fx:id="phoneClientColumn" prefWidth="250" />
                        <TableColumn text="Adresse" fx:id="addressClientColumn" prefWidth="250" />
                        <TableColumn text="Points de fidélité" fx:id="loyaltyClientColumn" prefWidth="150" />
                    </columns>
                </TableView>

                <!-- Pagination pour Clients -->
                <Pagination fx:id="paginationClient" />

                <!-- Boutons Ajouter, Modifier, Supprimer pour Clients -->
                <HBox spacing="10" alignment="CENTER">
                    <Button text="Modifier" fx:id="editClientButton" style="-fx-background-color: #B0BEC5; -fx-text-fill: white; -fx-font-size: 14px; -fx-border-radius: 5; -fx-background-radius: 5;" onAction="#openEditClientWindow"/>
                    <Button text="Supprimer" fx:id="deleteClientButton" style="-fx-background-color: #F44336; -fx-text-fill: white; -fx-font-size: 14px; -fx-border-radius: 5; -fx-background-radius: 5;"/>
                </HBox>
            </VBox>
        </Tab>
       <Tab text="Admins">
            <VBox spacing="10" style="-fx-padding: 10;">
                <!-- Barre de recherche pour Admins -->
                <HBox spacing="10" alignment="CENTER">
                    <TextField fx:id="searchAdminField" promptText="Rechercher un admin" style="-fx-background-color: white; -fx-border-radius: 5; -fx-font-size: 14px;" prefWidth="200"/>
                    <Button text="Rechercher" fx:id="searchAdminButton" style="-fx-background-color: rgb(7, 123, 173);  -fx-text-fill: white; -fx-font-size: 14px; -fx-border-radius: 5; -fx-background-radius: 5;"/>
                </HBox>

                <!-- TableView pour Admins -->
                <TableView fx:id="userTable" style="-fx-background-color: rgba(255, 255, 255, 0.1); -fx-background-radius: 10;">
                    <columns>
                        <TableColumn text="Nom" fx:id="nameUserColumn" prefWidth="250" />
                        <TableColumn text="Email" fx:id="emailUserColumn" prefWidth="250" />
                        <TableColumn text="Rôle" fx:id="roleUserColumn" prefWidth="250" />
                    </columns>
                </TableView>

                <!-- Pagination pour Admins -->
                <Pagination fx:id="paginationAdmin" />

                <!-- Boutons Ajouter, Modifier, Supprimer pour Admins -->
                <HBox spacing="10" alignment="CENTER">
                    <Button text="Ajouter" fx:id="addAdminButton" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-size: 14px; -fx-border-radius: 5; -fx-background-radius: 5;" onAction="#openAddUserWindow"/>
                    <Button text="Modifier" fx:id="editAdminButton" style="-fx-background-color: #B0BEC5; -fx-text-fill: white; -fx-font-size: 14px; -fx-border-radius: 5; -fx-background-radius: 5;" onAction="#openEditUserWindow"/>
                    <Button text="Supprimer" fx:id="deleteAdminButton" style="-fx-background-color: #F44336; -fx-text-fill: white; -fx-font-size: 14px; -fx-border-radius: 5; -fx-background-radius: 5;"/>
                </HBox>
            </VBox>
        </Tab>

        <Tab text="Parrains">
            <VBox spacing="10" style="-fx-padding: 10;">
                <!-- Barre de recherche pour Parrains -->
                <HBox spacing="10" alignment="CENTER">
                    <TextField fx:id="searchParrainField" promptText="Rechercher un parrain" style="-fx-background-color: white; -fx-border-radius: 5; -fx-font-size: 14px;" prefWidth="200"/>
                    <Button text="Rechercher" fx:id="searchParrainButton" style="-fx-background-color: rgb(7, 123, 173);  -fx-text-fill: white; -fx-font-size: 14px; -fx-border-radius: 5; -fx-background-radius: 5;"/>
                </HBox>

                <!-- TableView pour Parrains -->
                <TableView fx:id="parrainTable" style="-fx-background-color: rgba(255, 255, 255, 0.1); -fx-background-radius: 10;">
                    <columns>
                        <TableColumn text="Nom" fx:id="nameParrainColumn" prefWidth="250" />
                        <TableColumn text="Email" fx:id="emailParrainColumn" prefWidth="250" />
                        <TableColumn text="Téléphone" fx:id="phoneParrainColumn" prefWidth="150" />
                        <TableColumn text="Adresse" fx:id="addressParrainColumn" prefWidth="250" />
                        <TableColumn text="Code Parrainage" fx:id="codeParrainageColumn" prefWidth="150" />
                    </columns>
                </TableView>

                <!-- Pagination pour Parrains -->
                <Pagination fx:id="paginationParrain" />

                <!-- Boutons Ajouter, Modifier, Supprimer pour Parrains -->
                <HBox spacing="10" alignment="CENTER">
                    <Button text="Ajouter" fx:id="addParrainButton" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-size: 14px; -fx-border-radius: 5; -fx-background-radius: 5;" onAction="#openAddParrainWindow"/>
                    <Button text="Modifier" fx:id="editParrainButton" style="-fx-background-color: #B0BEC5; -fx-text-fill: white; -fx-font-size: 14px; -fx-border-radius: 5; -fx-background-radius: 5;" onAction="#openEditParrainWindow"/>
                    <Button text="Supprimer" fx:id="deleteParrainButton" style="-fx-background-color: #F44336; -fx-text-fill: white; -fx-font-size: 14px; -fx-border-radius: 5; -fx-background-radius: 5;" onAction="#deleteParrain"/>
                </HBox>
            </VBox>
        </Tab>
    </TabPane>
</AnchorPane>