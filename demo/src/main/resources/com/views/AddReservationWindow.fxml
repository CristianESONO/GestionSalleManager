<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<AnchorPane style="-fx-background-color: linear-gradient(to bottom, #13b0da, #0d8bbf);" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.controllers.AddReservationController">
    <children>
        <!-- Titre Ajouter Réservation -->
        <Text layoutX="30" layoutY="30" style="-fx-font-size: 24px; -fx-fill: white;" text="Ajouter une Réservation" />

        <!-- Grille pour organiser les champs -->
        <GridPane hgap="20" layoutX="30" layoutY="80" vgap="20" style="-fx-background-color: transparent;">
            <children>
                <!-- Colonne 1 : Informations client -->
                <VBox spacing="10" GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <Label text="Informations Client" style="-fx-font-size: 18px; -fx-text-fill: white;" />
                    <TextField fx:id="nameField" prefWidth="250" promptText="Nom" />
                    <TextField fx:id="phoneField" prefWidth="250" promptText="Numéro de téléphone" />
                    <DatePicker fx:id="birthDateField" prefWidth="250" promptText="Date de naissance" />
                    <TextField fx:id="addressField" prefWidth="250" promptText="Adresse" />
                    <TextField fx:id="loyaltyPointsField" prefWidth="250" promptText="Points de fidélité" />
                    <ComboBox fx:id="roleComboBox" prefWidth="250" promptText="Rôle" />
                </VBox>

                <!-- Colonne 2 : Informations de réservation -->
                <VBox spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <Label text="Informations de Réservation" style="-fx-font-size: 18px; -fx-text-fill: white;" />
                    <ComboBox fx:id="gameComboBox" prefWidth="250" promptText="Choisir un jeu" />
                    <ComboBox fx:id="posteComboBox" prefWidth="250" promptText="Choisir un poste" />
                    <ComboBox fx:id="durationComboBox" prefWidth="250" promptText="Choisir la durée" />
                    <TextField fx:id="codeParrainageField" prefWidth="250" promptText="Code parrainage (facultatif)" />
                </VBox>

                <!-- Boutons -->
                <HBox spacing="20" alignment="CENTER" GridPane.columnIndex="0" GridPane.columnSpan="2" GridPane.rowIndex="1">
                    <Button fx:id="addButton" text="Ajouter" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-size: 14px; -fx-border-radius: 5; -fx-background-radius: 5;" onAction="#addReservation" />
                    <Button fx:id="cancelButton" text="Annuler" style="-fx-background-color: #F44336; -fx-text-fill: white; -fx-font-size: 14px; -fx-border-radius: 5; -fx-background-radius: 5;" onAction="#cancel" />
                </HBox>
            </children>
            <columnConstraints>
                <ColumnConstraints />
                <ColumnConstraints />
            </columnConstraints>
            <rowConstraints>
                <RowConstraints />
                <RowConstraints />
            </rowConstraints>
        </GridPane>
    </children>
</AnchorPane>