<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.collections.FXCollections?>
<?import javafx.collections.ObservableList?>
<?import javafx.fxml.FXML?>
<?import javafx.scene.Scene?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.geometry.Insets?>
<?import javafx.stage.Stage?>
<?import javafx.scene.text.Text?>

<AnchorPane xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.controllers.GameSessionController" style="-fx-background-color: linear-gradient(to bottom, #13b0da, #0d8bbf);">
 <!-- Titre de la Vue -->
    <Text layoutX="30" layoutY="30" style="-fx-font-size: 24px; -fx-fill: white;" text="Gestion des Sessions de Jeux"/>

    <!-- Barre de recherche pour Sessions de Jeu -->
    <HBox spacing="10" alignment="CENTER" layoutY="10" AnchorPane.leftAnchor="10" AnchorPane.rightAnchor="10">
        <TextField fx:id="searchGameSessionField" promptText="Rechercher une session de jeu" style="-fx-background-color: white; -fx-border-radius: 5; -fx-font-size: 14px;"/>
        <Button text="Rechercher" fx:id="searchGameSessionButton" style="-fx-background-color: rgb(7, 123, 173); -fx-text-fill: white; -fx-font-size: 14px; -fx-border-radius: 5; -fx-background-radius: 5;"/>
    </HBox>

    <!-- TableView pour Sessions de Jeu -->
    <TableView fx:id="gameSessionTable" prefWidth="750" maxHeight="400" style="-fx-background-color: rgba(255, 255, 255, 0.1); -fx-background-radius: 10;" AnchorPane.topAnchor="50" AnchorPane.leftAnchor="10" AnchorPane.rightAnchor="10">
        <columns>
            <TableColumn text="ID" fx:id="idColumn" prefWidth="50" />
            <TableColumn text="Client" fx:id="clientColumn" prefWidth="150" />
            <TableColumn text="Jeu" fx:id="gameColumn" prefWidth="150" />
            <TableColumn text="Durée Payée (min)" fx:id="paidDurationColumn" prefWidth="150" />
            <TableColumn text="Statut" fx:id="statusColumn" prefWidth="100" />
        </columns>
    </TableView>

    <!-- Boutons Ajouter, Modifier, Supprimer pour Sessions de Jeu -->
    <HBox spacing="10" alignment="CENTER" layoutY="420.0" AnchorPane.bottomAnchor="10" AnchorPane.leftAnchor="10" AnchorPane.rightAnchor="10">
        <Button text="Ajouter" fx:id="addGameSessionButton" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-size: 14px; -fx-border-radius: 5; -fx-background-radius: 5;" onAction="#openAddGameSessionWindow"/>
        <Button text="Supprimer" fx:id="deleteGameSessionButton" style="-fx-background-color: #F44336; -fx-text-fill: white; -fx-font-size: 14px; -fx-border-radius: 5; -fx-background-radius: 5;" onAction="#deleteGameSession"/>
    </HBox>
</AnchorPane>
