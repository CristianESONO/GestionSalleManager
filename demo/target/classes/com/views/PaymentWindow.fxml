<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.controllers.PaymentController" 
      style="-fx-background-color: #FFFFFF; -fx-padding: 10; -fx-spacing: 10;">
    
    <!-- Sélection du client -->
    <Label text="Sélectionner un client :" />
    <ComboBox fx:id="clientComboBox" style="-fx-pref-width: 200px;" />
    
    <!-- Sélection du mode de paiement -->
    <Label text="Sélectionner un mode de paiement :" />
    <ComboBox fx:id="modePaiementComboBox" style="-fx-pref-width: 200px;" />
    
    <!-- Bouton Valider -->
    <Button text="Valider" onAction="#handleValider" 
            style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-size: 14px; -fx-border-radius: 5; -fx-background-radius: 5;" />
</VBox>