<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>

<AnchorPane xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.controllers.ProduitController" style="-fx-background-color: linear-gradient(to bottom, #13b0da, #0d8bbf);">
    
    <!-- Titre de la fenêtre -->
    <Text layoutX="20" layoutY="40" text="Gestion des Produits" 
          style="-fx-fill: white; -fx-font-size: 24px;">
        <font>
            <Font name="Arial" size="24" />
        </font>
    </Text>
    
    <!-- Bouton Ajouter produit et icône du panier -->
    <HBox layoutX="20" layoutY="80" spacing="10">
        <Button fx:id="btnAjouterProduit" text="Ajouter Produit" 
                style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-size: 14px; -fx-border-radius: 5; -fx-background-radius: 5;"
                onAction="#ajouterProduit"/>
        
        <!-- Icône du panier avec compteur -->
        <HBox alignment="CENTER" spacing="5" onMouseClicked="#showCart">
            <ImageView fx:id="cartIcon" fitHeight="24" fitWidth="24">
                <image>
                    <Image url="@../img/cart.png" />
                </image>
            </ImageView>
            <Text fx:id="cartCounter" text="0" style="-fx-fill: white; -fx-font-size: 16px;" />
        </HBox>
    </HBox>
    
    <!-- Zone de produits sous forme de grille -->
    <GridPane fx:id="gridProduits" hgap="20" vgap="20" layoutY="120" AnchorPane.leftAnchor="10" AnchorPane.rightAnchor="10">
        <!-- Les cartes de produits seront ajoutées ici dynamiquement -->
    </GridPane>
    
    <!-- Boutons de pagination -->
    <HBox spacing="20" layoutX="10" layoutY="560" AnchorPane.leftAnchor="10" AnchorPane.rightAnchor="10">
        <Button text="Précédent" onAction="#previousPage" 
                style="-fx-background-color: rgb(7, 123, 173); -fx-text-fill: white; -fx-font-size: 14px; -fx-border-radius: 5; -fx-background-radius: 5;"/>
        <Button text="Suivant" onAction="#nextPage" 
                style="-fx-background-color: rgb(7, 123, 173); -fx-text-fill: white; -fx-font-size: 14px; -fx-border-radius: 5; -fx-background-radius: 5;"/>
    </HBox>
    
</AnchorPane>